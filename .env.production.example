# =========================
# App
# =========================
NODE_ENV=production

# Use your real domain when ready.
# Example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# For first EC2 IP test:
# NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP/api
NEXT_PUBLIC_API_URL=http://16.171.142.99/

# =========================
# Backend API
# =========================
PORT=4000

# Generate a strong secret:
# openssl rand -hex 32
JWT_SECRET=D709C836-1F26-483E-9962-32E8B2839F52

# =========================
# Database - Amazon RDS PostgreSQL
# =========================
# Example:
# DATABASE_URL=postgresql://postgres:password@your-rds-endpoint.amazonaws.com:5432/note_share?schema=public
DATABASE_URL=postgresql://USERNAME:PASSWORD@RDS_ENDPOINT:5432/note_share?schema=public

# =========================
# Redis
# =========================
# In this first deployment Redis runs as a Docker container.
REDIS_HOST=redis
REDIS_PORT=6379

# =========================
# Storage
# =========================
STORAGE_DRIVER=s3

AWS_REGION=af-south-1
AWS_S3_BUCKET=your-s3-bucket-name

# Prefer EC2 IAM role in production.
# If using IAM role, leave these empty.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
AWS_S3_PUBLIC_BASE_URL=